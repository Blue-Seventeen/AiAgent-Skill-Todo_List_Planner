# Feishu app credentials from https://open.feishu.cn/
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# OpenAI-compatible chat completions endpoint.
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4.1-mini

# Local Todo List Planner Skill bridge.
TODO_SKILL_DIR=../todo-list-planner
TODO_MODE=live
TODO_PORT=9222

# Local runtime state. These paths are ignored by git.
AGENT_DATA_DIR=./data
ATTACHMENT_DIR=./data/attachments

# Optional: comma-separated trigger words for group chats when the bot is not @ mentioned.
GROUP_TRIGGER_WORDS=todo,待办,日程

# Optional: timezone for LLM planning context.
TIMEZONE=Asia/Shanghai
